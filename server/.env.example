PORT=5000
NODE_ENV=development
DB_USER=postgres
DB_PASSWORD=postgres123
DB_HOST=localhost
DB_PORT=5432
DB_NAME=jobtracker
# Optional: use a full connection string instead of DB_* values
# Example: postgresql://user:password@host:5432/database
DATABASE_URL=
# Set true for managed cloud databases that require SSL
DB_SSL=false
# Set false only when your provider uses self-signed certs
DB_SSL_REJECT_UNAUTHORIZED=true
JWT_SECRET=replace_with_strong_secret
DEV_RESET_KEY=optional_dev_reset_key
# Comma-separated allowed origins for browser requests
# Example: https://job-tracker-frontend.vercel.app,https://job-tracker-git-main-yourteam.vercel.app
CORS_ORIGINS=http://localhost:5173
